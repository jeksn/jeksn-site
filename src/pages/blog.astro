---
import Head from '../components/Head.astro';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const allPosts = Object.values(import.meta.glob('./blog/*.md', { eager: true }));

const title = 'Blog';
---

<Head title={title} />
<Layout>
	<Hero title={title} />
	<section class="py-12 px-4">
		<div class="mt-6 max-w-screen-lg mx-auto">
			<div class="pt-6 pb-44">
				<div class="flex justify-between items-center">
					<h2 class="text-2xl">All posts</h2>
					<button 
						x-data="{ copied: false }"
						@click="navigator.clipboard.writeText(window.location.origin + '/rss.xml'); copied = true; setTimeout(() => copied = false, 2000)"
						class="w-fit px-6 py-3 rounded-full flex items-center justify-center text-sm transition-all duration-150 ease-linear gap-2 bg-white/10 hover:bg-white/20">
						<span x-show="!copied">RSS FEED</span>
						<span x-show="copied">URL COPIED</span>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" x-show="!copied"><path d="M12.75 19.5v-.75a7.5 7.5 0 0 0-7.5-7.5H4.5m0-6.75h.75c7.87 0 14.25 6.38 14.25 14.25v.75M6 18.75a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" /></svg>
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" x-show="copied"><path d="M20 6 9 17l-5-5"/></svg>
					</button>
				</div>
				<ul class="grid grid-cols-1 md:grid-cols-2 gap-x-4 mt-6">
					{allPosts.sort((a: any, b: any) => (a.frontmatter.date < b.frontmatter.date) ? 1 : -1).map((post: any) => 
						<li>
							<a href={post.url} class="flex flex-col gap-3 p-6 my-2 card h-[150px] text-sm">
								<span class="text-lg">{post.frontmatter.title}</span>
								<span class="text-sm text-orange-100/80">{post.frontmatter.date}</span>
							</a>
						</li>
					)}
				  </ul>
			</div>
		</div>
	</section>
</Layout>


