---
import Head from '../components/Head.astro';
import LayoutLight from '../layouts/LayoutLight.astro';
import SmallHero from '../components/SmallHero.astro';

interface BlogPost {
	url: string;
	frontmatter: {
		title: string;
		date: string;
		description?: string;
	};
}

const allPosts = Object.values(import.meta.glob('./blog/*.md', { eager: true })) as BlogPost[];

const title = 'Blog';
const subtitle = "My infrequent writings.";
---

<LayoutLight>
	<Head slot="head" title={title} />
	<SmallHero title={title} subtitle={subtitle} />
	<section class="pt-12 pb-16 px-4">
		<div class="mt-6 max-w-screen-lg mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-5 gap-8">
				<!-- Left sidebar with static content -->
				<div class="md:col-span-1">
					<div class="sticky top-8 space-y-8">
						<div>
							<h3 class="text-lg font-medium text-orange-100 mb-4 font-departure">Blog</h3>
							<p class="text-sm text-[#939393] font-departure mb-4">A bit inconsistent, but thats's pretty typical when it comes to blogging.</p>
							<button
								aria-label="Copy RSS feed URL"
								x-data="{ copied: false }"
								@click="navigator.clipboard.writeText('https://jek.sn/rss.xml'); copied = true; setTimeout(() => copied = false, 2000)"
								class="mt-4 text-sm flex gap-x-2 items-center text-orange-100 hover:text-orange-200 font-departure transition-colors">
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" x-show="!copied">
									<path d="M4 11a9 9 0 0 1 9 9"></path>
									<path d="M4 4a16 16 0 0 1 16 16"></path>
									<circle cx="5" cy="19" r="1"></circle>
								</svg>
								<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" x-show="copied">
									<path d="M20 6 9 17l-5-5"></path>
								</svg>
								<span x-show="!copied">RSS Feed</span>
								<span x-show="copied">RSS copied!</span>
							</button>
						</div>
					</div>
				</div>

				<!-- Right content area with posts -->
				<div class="md:col-span-4">
					<div class="space-y-8">
						<div>
							<ul class="space-y-4">
								{allPosts.sort((a, b) => (a.frontmatter.date < b.frontmatter.date) ? 1 : -1).map((post) => 
									<li class="grid grid-cols-1 text-sm gap-2">
										<div class="space-y-1">
											<a href={post.url} class="text-orange-100 font-departure hover:underline flex gap-1"><span>{post.frontmatter.title}</span><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-up-right-icon lucide-arrow-up-right"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg></a>
											<p class="text-[#939393] font-departure">{post.frontmatter.date}</p>
										</div>
									</li>
								)}
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</LayoutLight>


